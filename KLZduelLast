local function getPromptPart(prompt)
    local parent = prompt.Parent
    if parent:IsA("BasePart") then return parent end
    if parent:IsA("Model") then
        return parent.PrimaryPart or parent:FindFirstChildWhichIsA("BasePart")
    end
    if parent:IsA("Attachment") then return parent.Parent end
    return parent:FindFirstChildWhichIsA("BasePart", true)
end

local function findNearestStealPrompt()
    local nearestPrompt = nil
    local minDist = math.huge
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end

    for _, desc in pairs(plots:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled and desc.ActionText == "Steal" then
            local part = getPromptPart(desc)
            if part then
                local dist = (HRP.Position - part.Position).Magnitude
                if dist < minDist and dist <= Values.STEAL_RADIUS then
                    minDist = dist
                    nearestPrompt = desc
                end
            end
        end
    end
    return nearestPrompt
end

local function ResetProgressBar()
    if ProgressLabel then ProgressLabel.Text = "READY" end
    if ProgressPercentLabel then ProgressPercentLabel.Text = "" end
    if ProgressBarFill then ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) end
end

local KLZ_TEXT = "KLZ Hub"
local function getKLZProgress(percent)
    local total = #KLZ_TEXT
    local adjusted = math.min(percent * 1.5, 100)
    local chars = math.floor((adjusted / 100) * total)
    return string.sub(KLZ_TEXT, 1, chars)
end

local function triggerPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(workspace) then return end
    if isStealingActive then return end
    
    isStealingActive = true
    
    if ProgressLabel then ProgressLabel.Text = "STEALING..." end
    
    if progressConnection then progressConnection:Disconnect() end
    progressConnection = RunService.Heartbeat:Connect(function()
        if not Enabled.AutoSteal then
            if progressConnection then progressConnection:Disconnect() end
            ResetProgressBar()
            isStealingActive = false
            return
        end
        -- Progress animation
        local prog = math.clamp((tick() % HOLD_DURATION) / HOLD_DURATION, 0, 1)
        if ProgressBarFill then ProgressBarFill.Size = UDim2.new(prog, 0, 1, 0) end
        if ProgressPercentLabel then
            local pct = math.floor(prog * 100)
            ProgressPercentLabel.Text = getKLZProgress(pct)
        end
    end)
    
    prompt.MaxActivationDistance = 9e9
    prompt.RequiresLineOfSight = false
    prompt.ClickablePrompt = true

    local usedFire = pcall(function()
        fireproximityprompt(prompt, 9e9, HOLD_DURATION)
    end)

    if not usedFire then
        pcall(function()
            prompt:InputHoldBegin()
            task.wait(HOLD_DURATION)
            prompt:InputHoldEnd()
        end)
    end
    
    task.wait(HOLD_DURATION)
    
    if progressConnection then progressConnection:Disconnect() end
    ResetProgressBar()
    isStealingActive = false
end

local autoStealConnection = nil
local function startAutoStealLoop()
    if autoStealConnection then return end
    autoStealConnection = task.spawn(function()
        while Enabled.AutoSteal do
            local prompt = findNearestStealPrompt()
            if prompt then
                triggerPrompt(prompt)
            end
            task.wait(stealCooldown)
        end
    end)
end

local function stopAutoStealLoop()
    if autoStealConnection then
        task.cancel(autoStealConnection)
        autoStealConnection = nil
    end
    isStealingActive = false
    ResetProgressBar()
end

